# Homeground frontend (public values embedded in the static site)
# Keep the form disabled until the real API, privacy notice and monitored inbox
# have passed the end-to-end receipt test.
NEXT_PUBLIC_HOMEGROUND_INQUIRY_ENABLED=false
NEXT_PUBLIC_HOMEGROUND_INQUIRY_API_URL=https://<project-ref>.supabase.co/functions/v1/v1-inquiries
# Optional emergency fallback after a confirmed non-save. If configured, it
# must point to the same monitored inbox as BRAND_NOTIFICATION_EMAIL below.
NEXT_PUBLIC_HOMEGROUND_BRAND_EMAIL=studio@example.test
NEXT_PUBLIC_HOMEGROUND_PRIVACY_READY=false
NEXT_PUBLIC_HOMEGROUND_PRIVACY_NOTICE_URL=/privacy/
NEXT_PUBLIC_HOMEGROUND_PRIVACY_NOTICE_URL_EN=/privacy/
NEXT_PUBLIC_HOMEGROUND_PRIVACY_NOTICE_URL_ZH=/zh/privacy/
NEXT_PUBLIC_HOMEGROUND_PRIVACY_NOTICE_URL_KO=/ko/privacy/
# Localized duration fragments only; the UI supplies "within / 内 / 이내".
NEXT_PUBLIC_HOMEGROUND_REPLY_SLA_EN=48 hours
NEXT_PUBLIC_HOMEGROUND_REPLY_SLA_ZH=48 小时
NEXT_PUBLIC_HOMEGROUND_REPLY_SLA_KO=48시간
# Public direct-chat link. This mode opens the studio WhatsApp Business
# conversation and does not submit an Inquiry to the API.
NEXT_PUBLIC_HOMEGROUND_DIRECT_WHATSAPP_ENABLED=false
# International digits only, with no "+" or spaces.
NEXT_PUBLIC_HOMEGROUND_WHATSAPP_NUMBER=8613174215999

# Supabase Edge Function: v1-inquiries (server-only)
SUPABASE_URL=https://<project-ref>.supabase.co
# Hosted Edge Functions inject the new JSON dictionary automatically. The code
# reads its "default" secret key and falls back to the legacy key while Supabase
# still provides it. These placeholders are only for local function serving;
# do not try to override either hosted default.
SUPABASE_SECRET_KEYS={"default":"<server-only-supabase-secret-key>"}
SUPABASE_SERVICE_ROLE_KEY=<legacy-server-only-service-role-key>
ALLOWED_ORIGINS=https://<production-origin>
ALLOWED_FORM_VERSIONS=2026-07-18.1,2026-07-19.1
ALLOWED_PRIVACY_NOTICE_VERSIONS=<published-privacy-notice-version>
# Emergency server-side kill switch. Setting this to false stops direct API
# submissions before their request bodies are read; the static frontend switch
# alone cannot stop a caller who already knows the public endpoint.
INQUIRY_ACCEPTING_SUBMISSIONS=true
# Legacy server-side saved-phone intake remains disabled. It is independent
# from NEXT_PUBLIC_HOMEGROUND_DIRECT_WHATSAPP_ENABLED.
WHATSAPP_ENABLED=false
IDEMPOTENCY_HASH_SECRET=<independent-high-entropy-secret>
RATE_LIMIT_HASH_SECRET=<different-high-entropy-secret>
RATE_LIMIT_10_MINUTES=5
RATE_LIMIT_24_HOURS=20
REPLY_SLA_HOURS=48

# Supabase Edge Function: notify-inquiries (server-only)
NOTIFICATION_WORKER_SECRET=<high-entropy-worker-secret>
# Emergency queue pause. New outbox rows remain stored and unsent until this
# returns to true; pause intake first so the queue cannot keep growing.
NOTIFICATION_PROCESSING_ENABLED=true
RESEND_API_KEY=<server-only-resend-api-key>
RESEND_FROM_EMAIL="Homeground <notifications@example.test>"
BRAND_NOTIFICATION_EMAIL=studio@example.test
NOTIFICATION_BATCH_SIZE=1
NOTIFICATION_LEASE_SECONDS=90
NOTIFICATION_PROVIDER_TIMEOUT_SECONDS=15

# Supabase Edge Function: inquiry-health (server-only)
# Use a different value from NOTIFICATION_WORKER_SECRET and RESEND_API_KEY.
OUTBOX_MONITOR_SECRET=<independent-high-entropy-monitor-secret>
# Non-PII traffic alert thresholds used by inquiry-health. Reaching a threshold
# makes the independent GitHub monitor fail so a person can pause intake.
INQUIRY_ALERT_10_MINUTES=10
INQUIRY_ALERT_1_HOUR=30
INQUIRY_ALERT_24_HOURS=100

# GitHub Actions repository variable. GitHub Actions stores the matching
# OUTBOX_MONITOR_SECRET value as an Actions secret, not a repository variable.
OUTBOX_HEALTH_URL=https://<project-ref>.supabase.co/functions/v1/inquiry-health

# Scheduler values are stored separately in Supabase Vault, never in the
# frontend or repository. See docs/inquiry-deployment.md:
# - homeground_notification_worker_url
# - homeground_notification_worker_secret (same value as the worker env above)
